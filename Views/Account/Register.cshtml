@{
    Layout = null;
}

@model LibraryManagementSystem.ViewModels.RegisterViewModel

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Register</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <style>

        body {
            margin: 0;
            height: 100vh;
            font-family: 'Segoe UI', sans-serif;
            overflow: hidden;
        }

        /* SPLIT LAYOUT */
        .auth-wrapper {
            display: flex;
            height: 100vh;
        }

        /* LEFT PANEL */
        .left-panel {
            flex: 1;
            background: linear-gradient(135deg, #0f172a, #1e3a8a, #2563eb);
            color: white;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 70px;
        }

            .left-panel h1 {
                font-size: 42px;
                font-weight: 700;
            }

            .left-panel p {
                opacity: 0.8;
                margin-top: 10px;
            }

        .features {
            margin-top: 30px;
        }

            .features div {
                margin-bottom: 10px;
                font-size: 14px;
                opacity: 0.9;
            }

        /* RIGHT PANEL */
        .right-panel {
            flex: 1;
            background: #f8fafc;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* CARD */
        .register-card {
            width: 420px;
            background: white;
            border-radius: 18px;
            padding: 30px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.15);
        }

            .register-card h3 {
                font-weight: 700;
                margin-bottom: 20px;
                color: #0f172a;
            }

        .form-control {
            border-radius: 10px;
            padding: 10px;
        }

        .btn-register {
            width: 100%;
            background: linear-gradient(135deg, #16a34a, #22c55e);
            border: none;
            padding: 10px;
            border-radius: 10px;
            color: white;
            font-weight: 600;
            transition: 0.3s;
        }

            .btn-register:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 25px rgba(34,197,94,0.3);
            }

        a {
            text-decoration: none;
            color: #2563eb;
        }

        /* PRIVATE KEY BOX */
        #keyBox {
            display: none;
            margin-top: 10px;
        }

    </style>
</head>

<body>

    <div class="auth-wrapper">

        <!-- LEFT -->
        <div class="left-panel">

            <h1>📚 Library System</h1>
            <p>Create an account to access smart library management system.</p>

            <div class="features">
                <div>✔ Manage Books</div>
                <div>✔ Track Borrow & Return</div>
                <div>✔ Membership System</div>
                <div>✔ Fine Calculation</div>
            </div>

        </div>

        <!-- RIGHT -->
        <div class="right-panel">

            <div class="register-card">

                <h3>Create Account</h3>

                <form asp-action="Register" method="post">

                    @Html.AntiForgeryToken()

                    <div class="mb-2">
                        <input asp-for="FullName" class="form-control" placeholder="Full Name" />
                    </div>

                    <div class="mb-2">
                        <input asp-for="Email" class="form-control" placeholder="Email" />
                    </div>

                    <div class="mb-2">
                        <input asp-for="Password" type="password" class="form-control" placeholder="Password" />
                    </div>

                    <div class="mb-2">
                        <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm Password" />
                    </div>

                    <!-- ADMIN CHECK -->
                    <div class="form-check mb-2">
                        <input type="checkbox"
                               id="isAdminCheck"
                               asp-for="IsAdmin"
                               class="form-check-input"
                               onclick="toggleKey()" />
                        <label class="form-check-label">Register as Admin</label>
                    </div>

                    <!-- PRIVATE KEY -->
                    <div id="keyBox">
                        <input asp-for="PrivateKey" class="form-control" placeholder="Admin Key" />
                    </div>

                    <button type="submit" class="btn-register mt-3">
                        Register
                    </button>

                    <div class="text-center mt-3">
                        <a asp-action="Login">Already have account?</a>
                    </div>

                </form>

            </div>

        </div>

    </div>

    <script>
        function toggleKey() {
            var box = document.getElementById("keyBox");
            var check = document.getElementById("isAdminCheck");

            box.style.display = check.checked ? "block" : "none";
        }
    </script>

</body>
</html>