@model IEnumerable<LibraryManagementSystem.Models.Book>

@{
    ViewData["Title"] = "Books";
}

<div class="container mt-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>📚 Books List</h2>
        <a class="btn btn-primary" asp-action="Create">+ Add Book</a>
    </div>


    <!-- ✅ SUCCESS MESSAGE HERE -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    <!-- Filters -->
    <div class="row mb-3">

        <!-- Search Box -->
        <div class="col-md-6 mb-2">
            <input type="text" id="searchBox" class="form-control" placeholder="Search by title or ISBN..." />
        </div>

        <!-- Category Filter -->
        <div class="col-md-6 mb-2">
            <select id="categoryFilter" class="form-select">
                <option value="">All Categories</option>
                @foreach (var item in Model.Select(x => x.Category?.Name).Distinct())
                {
                    <option value="@item">@item</option>
                }
            </select>
        </div>

    </div>

    <!-- Table -->
    <div class="card shadow-sm">
        <div class="card-body">

            <table class="table table-bordered table-hover" id="booksTable">
                <thead class="table-dark">
                    <tr>
                        <th>Title</th>
                        <th>ISBN</th>
                        <th>Author</th>
                        <th>Category</th>
                        <th>Total</th>
                        <th>Available</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Title</td>
                            <td>@item.ISBN</td>
                            <td>@item.Author?.Name</td>
                            <td class="category">@item.Category?.Name</td>
                            <td>@item.TotalCopies</td>
                            <td>@item.AvailableCopies</td>

                            <!-- FIX: Actions must be inside TD -->
                            <td>

                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-primary me-1">
                                    View
                                </a>

                                <a asp-action="Edit" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-warning me-1">
                                    Edit
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-danger">
                                    Delete
                                </a>

                            </td>

                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {

            // 🔍 Search filter
            $("#searchBox").on("keyup", function () {
                let value = $(this).val().toLowerCase();

                $("#booksTable tbody tr").each(function () {
                    let rowText = $(this).text().toLowerCase();
                    $(this).toggle(rowText.includes(value));
                });
            });

            // 📂 Category filter
            $("#categoryFilter").on("change", function () {
                let value = $(this).val().toLowerCase();

                $("#booksTable tbody tr").each(function () {
                    if (!value) {
                        $(this).show();
                    } else {
                        let category = $(this).find(".category").text().toLowerCase();
                        $(this).toggle(category.includes(value));
                    }
                });
            });
        });
    </script>
}