@model IEnumerable<LibraryManagementSystem.ViewModels.TopBorrowerViewModel>

@{
    ViewData["Title"] = "Top Borrowers Report";
}

<div class="container mt-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>🏆 Top 10 Active Borrowers</h3>
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
            ⬅ Back
        </a>
    </div>

    <!-- Table -->
    <div class="card shadow-sm">
        <div class="card-body">

            <table class="table table-bordered table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Rank</th>
                        <th>Member Name</th>
                        <th>Total Books Borrowed</th>
                    </tr>
                </thead>

                <tbody>
                    @{
                        int rank = 1;
                    }

                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <span class="badge bg-primary">@rank</span>
                                </td>

                                <td>@item.MemberName</td>

                                <td>
                                    <span class="badge bg-success">
                                        @item.TotalBooks
                                    </span>
                                </td>
                            </tr>

                            rank++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center text-muted">
                                No data available
                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>

</div>