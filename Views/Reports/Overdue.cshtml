@model IEnumerable<LibraryManagementSystem.Models.BorrowRecord>

@{
    ViewData["Title"] = "Overdue Books Report";
}

<div class="container mt-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>⏰ Overdue Books Report</h3>
        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
            ⬅ Back
        </a>
    </div>

    <!-- Table -->
    <div class="card shadow-sm">
        <div class="card-body">

            <table class="table table-bordered table-hover">
                <thead class="table-danger">
                    <tr>
                        <th>Book</th>
                        <th>Member</th>
                        <th>Issued On</th>
                        <th>Due Date</th>
                        <th>Days Late</th>
                        <th>Fine (₹10/day)</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            var daysLate = (DateTime.Now - item.DueDate).Days;
                            var fine = daysLate * 10;

                            <tr>
                                <td>@item.Book?.Title</td>
                                <td>@item.Member?.Name</td>
                                <td>@item.IssuedOn.ToString("dd-MM-yyyy")</td>
                                <td>@item.DueDate.ToString("dd-MM-yyyy")</td>

                                <td class="text-danger fw-bold">
                                    @daysLate days
                                </td>

                                <td class="text-danger fw-bold">
                                    ₹ @fine
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-success">
                                🎉 No overdue books found
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>

</div>