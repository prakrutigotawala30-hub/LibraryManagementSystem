@model LibraryManagementSystem.ViewModels.DashboardViewModel

<div class="container-fluid py-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">📊 Dashboard</h2>
            <p class="text-muted mb-0">
                Library Management System Overview
            </p>
        </div>

        <div>
            <a asp-controller="Membership"
               asp-action="Index"
               class="btn btn-dark shadow-sm px-4">
                <i class="bi bi-card-checklist"></i>
                Memberships
            </a>
        </div>
    </div>

    <!-- STATISTICS -->
    <div class="row g-4">

        <!-- TOTAL BOOKS -->
        <div class="col-xl-3 col-md-6">
            <div class="card dashboard-card bg-primary text-white border-0">
                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="small mb-1">Total Books</p>
                            <h2 class="fw-bold">@Model.TotalBooks</h2>
                        </div>

                        <div class="icon-box">
                            <i class="bi bi-book"></i>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- ISSUED BOOKS -->
        <div class="col-xl-3 col-md-6">
            <div class="card dashboard-card bg-success text-white border-0">
                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="small mb-1">Issued Books</p>
                            <h2 class="fw-bold">@Model.IssuedBooks</h2>
                        </div>

                        <div class="icon-box">
                            <i class="bi bi-journal-arrow-down"></i>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- OVERDUE -->
        <div class="col-xl-3 col-md-6">
            <div class="card dashboard-card bg-danger text-white border-0">
                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="small mb-1">Overdue Books</p>
                            <h2 class="fw-bold">@Model.OverdueBooks</h2>
                        </div>

                        <div class="icon-box">
                            <i class="bi bi-exclamation-triangle"></i>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- MEMBERS -->
        <div class="col-xl-3 col-md-6">
            <div class="card dashboard-card bg-dark text-white border-0">
                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="small mb-1">Total Members</p>
                            <h2 class="fw-bold">@Model.TotalMembers</h2>
                        </div>

                        <div class="icon-box">
                            <i class="bi bi-people"></i>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- ACTIVE MEMBERSHIPS -->
        <div class="col-xl-3 col-md-6">
            <div class="card dashboard-card membership-active border-0 text-white">
                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="small mb-1">Active Memberships</p>
                            <h2 class="fw-bold">@Model.ActiveMemberships</h2>
                        </div>

                        <div class="icon-box">
                            <i class="bi bi-patch-check"></i>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- EXPIRED MEMBERSHIPS -->
        <div class="col-xl-3 col-md-6">
            <div class="card dashboard-card membership-expired border-0 text-white">
                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="small mb-1">Expired Memberships</p>
                            <h2 class="fw-bold">@Model.ExpiredMemberships</h2>
                        </div>

                        <div class="icon-box">
                            <i class="bi bi-patch-exclamation"></i>
                        </div>
                    </div>

                </div>
            </div>
        </div>

    </div>

    <!-- MEMBERSHIP SECTION -->
    <div class="card border-0 shadow-sm mt-5 membership-banner">

        <div class="card-body p-4">

            <div class="row align-items-center">

                <div class="col-lg-8">

                    <h3 class="fw-bold text-white mb-3">
                        🎫 Library Membership System
                    </h3>

                    <p class="text-light mb-3">
                        Members must have active membership to issue books.
                    </p>

                    <div class="row g-3">

                        <div class="col-md-4">
                            <div class="membership-type-card">
                                <i class="bi bi-mortarboard-fill"></i>
                                <h6 class="mt-3">Student</h6>

                                <small>
                                    3 Months - ₹400 <br />
                                    6 Months - ₹600 <br />
                                    1 Year - ₹1000
                                </small>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="membership-type-card">
                                <i class="bi bi-person-badge-fill"></i>
                                <h6 class="mt-3">Regular</h6>

                                <small>
                                    6 Months - ₹800 <br />
                                    1 Year - ₹1500
                                </small>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="membership-type-card">
                                <i class="bi bi-award-fill"></i>
                                <h6 class="mt-3">Premium</h6>

                                <small>
                                    1 Year - ₹2500 <br />
                                    Unlimited Borrow
                                </small>
                            </div>
                        </div>

                    </div>

                </div>

                <div class="col-lg-4 text-center mt-4 mt-lg-0">

                    <a asp-controller="Membership"
                       asp-action="Create"
                       class="btn btn-light btn-lg px-5 py-3 shadow">

                        <i class="bi bi-plus-circle"></i>
                        Add Membership

                    </a>

                    <div class="mt-3">
                        <a asp-controller="Membership"
                           asp-action="Index"
                           class="text-white text-decoration-none">
                            View Membership Records →
                        </a>
                    </div>

                </div>

            </div>

        </div>

    </div>

    <!-- RECENT BORROWS -->
    <div class="card border-0 shadow-sm mt-5">

        <div class="card-header bg-white border-0 pt-4 pb-0">

            <div class="d-flex justify-content-between align-items-center">

                <h5 class="fw-bold mb-0">
                    📚 Recent Borrow Activity
                </h5>

                <a asp-controller="Borrow"
                   asp-action="Index"
                   class="btn btn-sm btn-outline-dark">
                    View All
                </a>

            </div>

        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table class="table align-middle">

                    <thead class="table-light">
                        <tr>
                            <th>Book</th>
                            <th>Member</th>
                            <th>Issued Date</th>
                            <th>Due Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var item in (List<LibraryManagementSystem.Models.BorrowRecord>)ViewBag.RecentBorrows)
                        {
                            <tr>

                                <td class="fw-semibold">
                                    @item.Book?.Title
                                </td>

                                <td>
                                    @item.Member?.Name
                                </td>

                                <td>
                                    @item.IssuedOn.ToShortDateString()
                                </td>

                                <td>
                                    @item.DueDate.ToShortDateString()
                                </td>

                                <td>

                                    @if (item.ReturnedOn == null)
                                    {
                                        if (item.DueDate < DateTime.Now)
                                        {
                                            <span class="badge bg-danger px-3 py-2">
                                                Overdue
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark px-3 py-2">
                                                Borrowed
                                            </span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge bg-success px-3 py-2">
                                            Returned
                                        </span>
                                    }

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

<style>

    body {
        background: #f4f7fb;
    }

    .dashboard-card {
        border-radius: 18px;
        transition: all 0.3s ease;
        overflow: hidden;
    }

        .dashboard-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.15);
        }

    .icon-box {
        width: 65px;
        height: 65px;
        background: rgba(255,255,255,0.2);
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
    }

    .membership-active {
        background: linear-gradient(135deg,#0891b2,#06b6d4);
    }

    .membership-expired {
        background: linear-gradient(135deg,#6b7280,#4b5563);
    }

    .membership-banner {
        border-radius: 24px;
        background: linear-gradient(135deg,#0f172a,#1e293b);
    }

    .membership-type-card {
        background: rgba(255,255,255,0.08);
        border-radius: 16px;
        padding: 20px;
        text-align: center;
        color: white;
        backdrop-filter: blur(10px);
        transition: 0.3s;
    }

        .membership-type-card:hover {
            transform: translateY(-5px);
            background: rgba(255,255,255,0.15);
        }

        .membership-type-card i {
            font-size: 40px;
        }

    table tbody tr:hover {
        background: #f8fafc;
    }

    .table {
        border-radius: 12px;
        overflow: hidden;
    }

</style>