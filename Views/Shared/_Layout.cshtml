@using Microsoft.AspNetCore.Identity
@inject UserManager<LibraryManagementSystem.Models.ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Library System</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>

        body {
            background: #f4f6f9;
            overflow-x: hidden;
        }

        /* ===== TOP NAVBAR (LOGIN ONLY) ===== */
        .top-navbar {
            height: 60px;
            background: #111827;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 20px;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            color: white;
        }

        .brand {
            font-weight: 700;
            font-size: 18px;
        }

        /* ===== SIDEBAR ===== */
        .sidebar {
            width: 240px;
            height: 100vh;
            background: #1f2937;
            position: fixed;
            top: 60px;
            left: 0;
            padding-top: 20px;
        }

            .sidebar a {
                display: block;
                color: #e5e7eb;
                padding: 12px 20px;
                text-decoration: none;
                transition: 0.2s;
            }

                .sidebar a:hover {
                    background: #374151;
                    color: #38bdf8;
                }

        /* ===== CONTENT ===== */
        .content {
            margin-left: 240px;
            margin-top: 70px;
            padding: 20px;
        }

        footer {
            text-align: center;
            padding: 15px;
            color: #9ca3af;
        }

    </style>
</head>

<body>

    <!-- TOP NAVBAR (ONLY LOGIN) -->
    <div class="top-navbar">

        <div class="brand">
            📚 Library System
        </div>

        <div>

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                var user = await UserManager.GetUserAsync(User);

                <span class="me-3 text-warning">
                    👤 @(user?.FullName ?? user?.Email)
                </span>

                <a class="btn btn-sm btn-danger" asp-controller="Account" asp-action="Logout">
                    Logout
                </a>
            }
            else
            {
                <a class="btn btn-sm btn-primary" asp-controller="Account" asp-action="Login">
                    Login
                </a>

            }

        </div>

    </div>

    <!-- SIDEBAR -->
    <div class="sidebar">

        <a asp-controller="Home" asp-action="Index">
            <i class="bi bi-speedometer2"></i> Dashboard
        </a>

        <a asp-controller="Books" asp-action="Index">
            <i class="bi bi-book"></i> Books
        </a>

        <a asp-controller="Authors" asp-action="Index">
            <i class="bi bi-person"></i> Authors
        </a>

        <a asp-controller="Categories" asp-action="Index">
            <i class="bi bi-folder"></i> Categories
        </a>

        <a asp-controller="Members" asp-action="Index">
            <i class="bi bi-people"></i> Members
        </a>

        <a class="nav-link"
           asp-controller="Membership" asp-action="Index">
            <i class="bi bi-person-vcard"></i> Memberships
        </a>

        <a asp-controller="Borrow" asp-action="Index">
            <i class="bi bi-journal-arrow-down"></i> Borrow
        </a>

        <a asp-controller="Reports" asp-action="Overdue">
            ⏰ Overdue Report
        </a>

        <a asp-controller="Reports" asp-action="TopBorrowers">
            🏆 Top Borrowers
        </a>

        <a class="nav-link" asp-controller="Home" asp-action="Contact">📞 Contact Us</a>

        <a asp-controller="Home" asp-action="Privacy">
            <i class="bi bi-shield-lock"></i> Privacy
        </a>

    </div>

    <!-- MAIN CONTENT -->
    <div class="content">
        @RenderBody()
    </div>

    <footer>
        © 2026 Library Management System
    </footer>

    @RenderSection("Scripts", required: false)

</body>
</html>